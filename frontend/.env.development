# Dev mode: empty base → client calls same-origin /api/v1, forwarded by the Vite
# proxy in vite.config.ts (no backend CORS needed for local development).
# Override the proxy target with VITE_API_PROXY_TARGET if your backend is elsewhere.
VITE_API_BASE=
VITE_API_PROXY_TARGET=http://136.109.192.193:8000
