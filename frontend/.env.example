# Base URL of the PR Health backend API (no trailing slash).
# Public LoadBalancer of the deployed backend in the hack06-pr-health namespace.
VITE_API_BASE=http://136.109.192.193:8000

# Bearer token for saving Scoring Settings (the PUT/DELETE /scoring-config routes).
# Set this to the backend's FASTAPI_AUTH_TOKEN. Leave empty for read-only use;
# saving will then show a clear "needs an admin token" message.
VITE_ADMIN_TOKEN=
