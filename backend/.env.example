# Copy to .env and adjust. Every var is optional; defaults make the app boot on
# SQLite with zero setup. Names map 1:1 to app/config.py:Settings (case-insensitive).

# --- Persistence ---
# SQLite (default, zero-setup):
DATABASE_URL=sqlite:///./dev.db
# PostgreSQL (via docker-compose):
# DATABASE_URL=postgresql+psycopg2://prhealth:prhealth@localhost:5432/prhealth

# --- Auth (bearer token required on POST routes) ---
FASTAPI_AUTH_TOKEN=dev-token

# --- GitHub provider ---
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# --- Harness SCM provider (interface-complete; fill in to use provider=harness) ---
HARNESS_TOKEN=
HARNESS_API_URL=https://app.harness.io
HARNESS_ACCOUNT_ID=
HARNESS_ORG_ID=
HARNESS_PROJECT_ID=

# --- LLM (narration only; never affects scores) ---
LLM_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# cost-effective alternative: claude-sonnet-4-6
LLM_MAX_TOKENS=1024

# --- Writeback (PR comment + commit status) ---
WRITEBACK_ENABLED=false

# --- CI analysis ---
# Comma-separated names treated as "required". Empty => every check is required.
REQUIRED_CHECKS=

# --- Scoring / analyzer thresholds (tunable; defaults shown) ---
READY_THRESHOLD=70
MERGE_FAST_MINUTES=15
MERGE_SLOW_MINUTES=60
CHANGE_MEDIUM_LINES=250
CHANGE_HIGH_LINES=500
CHANGE_CRITICAL_LINES=1000
CHANGE_HIGH_FILES=30
REVIEW_TRIVIAL_LINES=10
REVIEW_THIN_REVIEWERS=2
